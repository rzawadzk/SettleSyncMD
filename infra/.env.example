# SettleSync Docker Compose Environment
# Copy to .env and fill in your values

# ============================================================
# DATABASE
# ============================================================
POSTGRES_DB=settlesync
POSTGRES_USER=settlesync
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ============================================================
# SECURITY (generate with: openssl rand -hex 32)
# ============================================================
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32

# ============================================================
# APPLICATION
# ============================================================
APP_URL=https://mediation.yourfirm.com
API_URL=http://backend:3001
LOG_LEVEL=info

# ============================================================
# EMAIL
# ============================================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourfirm.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourfirm.com
SMTP_FROM_NAME=YourFirm Mediation

# ============================================================
# ADMIN
# ============================================================
ADMIN_EMAILS=mediator@yourfirm.com

# ============================================================
# PARTY TOKENS
# ============================================================
TOKEN_TTL_HOURS=72
MAX_UPLOAD_MB=10

# ============================================================
# PORTS
# ============================================================
HTTP_PORT=80
HTTPS_PORT=443
