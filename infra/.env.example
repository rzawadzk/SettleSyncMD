# SettleSync — Environment Variables
# Skopiuj do .env i uzupełnij wartości

# Backend
PORT=3001
NODE_ENV=development

# Database (SQLite dla dev, PostgreSQL dla prod)
DATABASE_URL=./data/settlesync.db

# Security — ZMIEŃ W PRODUKCJI!
JWT_SECRET=change-me-to-a-random-64-char-string
HMAC_SECRET=change-me-to-a-different-random-64-char-string

# Frontend URL (do linków w emailach i CORS)
FRONTEND_URL=http://localhost:5173

# Email (pozostaw puste dla Ethereal test w dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@settlesync.app

# Docker PostgreSQL (używane w docker-compose)
POSTGRES_USER=settlesync
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=settlesync
