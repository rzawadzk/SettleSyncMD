# SettleSync — Production Environment Variables
# Copy to .env and fill in values. The deploy script generates secrets automatically.

# Domain (used for SSL certificate and nginx)
DOMAIN=settlesync.example.com

# Frontend URL (used in email links and CORS)
FRONTEND_URL=https://settlesync.example.com

# PostgreSQL
POSTGRES_USER=settlesync
POSTGRES_PASSWORD=  # generated by deploy.sh
POSTGRES_DB=settlesync

# Redis (internal Docker network — no need to change)
REDIS_URL=redis://redis:6379

# Security secrets — MUST be unique random strings
JWT_SECRET=    # generated by deploy.sh
HMAC_SECRET=   # generated by deploy.sh

# Backend
PORT=3001
NODE_ENV=production

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@settlesync.app

# Certbot email (for SSL certificate notifications)
CERTBOT_EMAIL=
